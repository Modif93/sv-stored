{
	"name": "sv-stored",
	"description": "Zustand-style middleware composition for Svelte stores.",
	"version": "0.0.2",
	"type": "module",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"license": "MIT",
	"keywords": [
		"svelte",
		"svelte5",
		"sveltekit",
		"svelte utilities",
		"svelte helpers",
		"sveltekit utilities",
		"sveltekit helpers",
		"svelte 5 stores",
		"stores",
		"typescript"
	],
	"contributors": [
		{
			"name": "Youngkyu Cho",
			"url": "https://github.com/modif93"
		}
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/modif93/sv-stored",
		"directory": "packages/stored"
	},
	"scripts": {
		"dev": "pnpm sync && pnpm watch",
		"build": "pnpm package",
		"package": "svelte-kit sync && svelte-package && publint",
		"test": "vitest --run && playwright test",
		"test:unit": "vitest --watch",
		"test:watch": "vitest --watch",
		"test:ui": "vitest --watch --ui",
		"test:integration": "playwright test",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"watch": "svelte-kit sync && svelte-package --watch"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"svelte": "^5.7.0",
		"@sveltejs/kit": "^2.21.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.55.0",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/package": "^2.3.0",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@testing-library/dom": "^10.2.0",
		"@testing-library/jest-dom": "^6.4.6",
		"@testing-library/svelte": "^5.2.0",
		"@testing-library/user-event": "^14.5.2",
		"@types/node": "catalog:",
		"@vitest/browser": "^3.2.4",
		"@vitest/coverage-v8": "^3.2.4",
		"@vitest/ui": "^3.2.4",
		"jsdom": "^24.0.0",
		"playwright": "^1.55.0",
		"publint": "^0.1.9",
		"resize-observer-polyfill": "^1.5.1",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tslib": "^2.4.1",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "^3.2.4"
	}
}
